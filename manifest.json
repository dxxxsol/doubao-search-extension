{
  "manifest_version": 3,
  "name": "豆包对话搜索",
  "version": "1.0.0",
  "description": "为豆包聊天页面添加聊天记录搜索功能",
  "permissions": [],
  "host_permissions": [
    "https://www.doubao.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.doubao.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
